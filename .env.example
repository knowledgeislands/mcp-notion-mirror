# ─────────────────────────────────────────────────────────────────────────
# mcp-notion-mirror — environment template.
# Copy to `.env.development` for local `bun run server:mcp:dev`, or set these
# in your MCP client's `env` block. See README.md for full setup. `.env.*`
# files are gitignored; only `.env*.example` templates are committed.
# ─────────────────────────────────────────────────────────────────────────

# Notion internal-integration secret (`ntn_…`). Required. Create an internal
# integration, grant it Read + Insert + Update content, and connect it to the
# target page/database (otherwise Notion returns restricted_resource / 403).
MCP_NOTION_MIRROR_TOKEN=ntn_your_integration_secret_here

# Absolute or `~`-prefixed KB root. When set, `kb_path` arguments resolve under
# it and are confined to it; when unset, `kb_path` must be absolute.
# MCP_NOTION_MIRROR_KB_ROOT=~/path/to/your/kb

# Notion API base URL. Default: https://api.notion.com
# MCP_NOTION_MIRROR_API_BASE_URL=https://api.notion.com

# The "Mirrored from Knowledge Base" banner callout. `{date}` interpolates
# today's UTC date; `**bold**` is honoured; an empty string disables the
# banner. See README.md for the long default value.
# MCP_NOTION_MIRROR_BANNER_TEMPLATE=

# ─────────────────────────────────────────────────────────────────────────
# Access level & audit log — conventions shared across all HNR MCP servers.
# ─────────────────────────────────────────────────────────────────────────

# Maximum access level to register at server boot. One of: read, write,
# destructive. Levels nest: `read` registers only read-only tools; `write`
# adds non-destructive mutations; `destructive` adds delete/overwrite tools.
# A tool's level is derived from its MCP annotations (readOnlyHint /
# destructiveHint), not its name — see src/utils/access-level.ts.
# Default: write.
# MCP_NOTION_MIRROR_ACCESS_LEVEL=destructive

# Audit log of tool invocations, written as JSONL. One of: off, writes, all.
#   off    — no audit logging
#   writes — record write/destructive calls only (default)
#   all    — record every call, including reads
# MCP_NOTION_MIRROR_AUDIT_LOG=writes

# Path to the audit log file.
# MCP_NOTION_MIRROR_AUDIT_LOG_PATH=~/.local/state/mcp-notion-mirror/audit.jsonl

# Rotate the audit log when it exceeds this many bytes (0 disables rotation).
# Default: 10485760 (10 MiB).
# MCP_NOTION_MIRROR_AUDIT_LOG_MAX_BYTES=10485760

# Number of rotated audit logs to keep. Default: 5.
# MCP_NOTION_MIRROR_AUDIT_LOG_KEEP=5
